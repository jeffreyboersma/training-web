# Public-safe Supabase browser configuration
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional override when edge functions are served from a different base URL
VITE_SUPABASE_EDGE_FUNCTION_URL=

# Required for GitHub Pages project-site deployments; use / for a custom domain at the site root
VITE_APP_BASE_PATH=/training-web/
