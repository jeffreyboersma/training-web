# Public-safe Supabase browser configuration
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional override when edge functions are served from a different base URL
VITE_SUPABASE_EDGE_FUNCTION_URL=

# Use / for local development. CI or deploy env vars should set the Pages base path when needed.
VITE_APP_BASE_PATH=/

# Optional canonical public origin for auth callbacks, useful for cross-device magic-link flows.
VITE_APP_ORIGIN=
